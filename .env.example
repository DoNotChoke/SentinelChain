# ─────────────────────────────────────────────────────────────────────────────
# SentinelChain — environment configuration template
# Copy to `.env` and adjust. NEVER commit `.env` (see .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# --- Deployment profile ---------------------------------------------------------
# Drives docker-compose profile selection: dev (single Kafka broker) | prod
SENTINEL_ENV=dev

# --- Kafka / Schema Registry ----------------------------------------------------
# dev profile exposes a single broker; prod profile uses 3.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_TOPIC_REPLICATION_FACTOR=1
KAFKA_TOPIC_MIN_INSYNC_REPLICAS=1

# --- PostgreSQL (operational store + CDC source) --------------------------------
POSTGRES_DSN=postgresql://sentinel:sentinel@localhost:5432/sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel

# --- Kafka Connect / Debezium (CDC) ---------------------------------------------
KAFKA_CONNECT_URL=http://localhost:8083

# --- Supply-chain simulator -----------------------------------------------------
SIMULATOR_TICK_INTERVAL_SECONDS=2.0
SIMULATOR_SEED_ON_START=true
SIMULATOR_RUN_LOOP=true
# SIMULATOR_RANDOM_SEED=42          # set to make a run reproducible
SIMULATOR_HEALTH_PORT=8080
METRICS_PORT=9100

# --- OpenSearch -----------------------------------------------------------------
OPENSEARCH_URL=http://localhost:9200

# --- Redis ----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- MinIO (object store for Iceberg / artifacts) -------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- MLflow ---------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Observability --------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinelchain
LOG_LEVEL=INFO

# --- Ingestion poll intervals (seconds) -----------------------------------------
USGS_POLL_INTERVAL_SECONDS=60
GDACS_POLL_INTERVAL_SECONDS=300
GDELT_POLL_INTERVAL_SECONDS=900

# --- Embeddings -----------------------------------------------------------------
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3

# --- LLM (via llm-gateway abstraction; see docs/IMPLEMENTATION_PLAN.md §D) -------
# Provider: mock | anthropic | openai-compatible | vllm
LLM_PROVIDER=mock
LLM_MODEL=claude-opus-4-8
LLM_API_BASE=
LLM_API_KEY=
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.0

# --- Risk thresholds ------------------------------------------------------------
RISK_CRITICAL_THRESHOLD=0.80
RISK_HIGH_THRESHOLD=0.60
RISK_MEDIUM_THRESHOLD=0.40

# --- Tenancy --------------------------------------------------------------------
DEFAULT_TENANT_ID=demo
