# Normalize line endings. Shell scripts MUST be LF so they run in Linux containers
# even when checked out on Windows.
* text=auto eol=lf

*.sh        text eol=lf
*.bash      text eol=lf
Makefile    text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf

# Windows-only scripts keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.avro      binary
